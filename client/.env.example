# Client ID público do aplicativo criado no Spotify Developer Dashboard.
VITE_SPOTIFY_CLIENT_ID=COLOQUE_SEU_CLIENT_ID

# Deve ser cadastrado exatamente igual no Spotify Dashboard.
# É sempre 127.0.0.1 (loopback local do app) — NÃO é o IP do servidor.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:43821/callback

# Apenas valor inicial. O usuário pode trocar esta URL dentro do Electron.
# Servidor real (LAN): http://192.168.230.217:3333
VITE_DEFAULT_SERVER_URL=http://192.168.230.217:3333
